# Copy this file to .env and fill in your own free-tier credentials.
# NEVER commit the real .env file.

PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,https://YOUR_GITHUB_USERNAME.github.io

# Supabase (free tier) - Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Firebase Admin SDK (free Spark plan) - Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Comma-separated emails allowed to access /api/admin/* routes
ADMIN_EMAILS=you@example.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Cache TTLs (seconds)
CACHE_TTL_QUOTE_SECONDS=60
CACHE_TTL_HISTORY_SECONDS=3600
CACHE_TTL_NEWS_SECONDS=900
